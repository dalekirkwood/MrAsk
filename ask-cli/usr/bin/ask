#!/bin/bash

# Support both snap and regular installations
if [[ -n "$SNAP_USER_DATA" ]]; then
    CONFIG_DIR="$SNAP_USER_DATA/.config/ask"
else
    CONFIG_DIR="$HOME/.config/ask"
fi

CONFIG_FILE="$CONFIG_DIR/config.conf"
HISTORY_FILE="$CONFIG_DIR/history.json"
CACHE_DIR="$HOME/.cache/ask"
RESPONSE_CACHE_DIR="$CACHE_DIR/responses"

mkdir -p "$CONFIG_DIR"
mkdir -p "$CACHE_DIR"
mkdir -p "$RESPONSE_CACHE_DIR"

DEFAULT_MODEL="openrouter/auto"
DEFAULT_ENDPOINT="https://openrouter.ai/api/v1/chat/completions"

# Spinner animation
spinner() {
    local pid=$1
    local delay=0.1
    local spinstr='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    while kill -0 "$pid" 2>/dev/null; do
        local temp=${spinstr#?}
        printf "\r%s Querying AI... (%s)" "${spinstr:0:1}" "$MODEL" >&2
        spinstr=$temp${spinstr:0:1}
        sleep $delay
    done
    printf "\r\n" >&2
}

# Get cache key for a question
get_cache_key() {
    local question="$1"
    echo "$question" | sha256sum | cut -d' ' -f1
}

# Check cache for existing response
check_cache() {
    local question="$1"
    local cache_key
    cache_key=$(get_cache_key "$question")
    local cache_file="$RESPONSE_CACHE_DIR/${cache_key}.json"
    
    if [[ -f "$cache_file" ]]; then
        local age
        age=$(( $(date +%s) - $(stat -c %Y "$cache_file" 2>/dev/null || stat -f %m "$cache_file") ))
        # Cache valid for 24 hours (86400 seconds)
        if [[ $age -lt 86400 ]]; then
            cat "$cache_file"
            return 0
        fi
    fi
    return 1
}

# Save response to cache (only if valid)
save_cache() {
    local question="$1"
    local response="$2"
    
    # Only cache if response is valid JSON with choices
    if ! echo "$response" | jq -e '.choices' > /dev/null 2>&1; then
        return 1
    fi
    
    local cache_key
    cache_key=$(get_cache_key "$question")
    local cache_file="$RESPONSE_CACHE_DIR/${cache_key}.json"
    
    # Limit cache to 100 files
    if [[ $(ls -1 "$RESPONSE_CACHE_DIR" 2>/dev/null | wc -l) -gt 100 ]]; then
        ls -1t "$RESPONSE_CACHE_DIR" 2>/dev/null | tail -n +101 | xargs -I {} rm -f "$RESPONSE_CACHE_DIR/{}"
    fi
    
    echo "$response" > "$cache_file"
}

extract_commands_json() {
    local content="$1"
    local cleaned
    local extracted

    cleaned=$(printf '%s' "$content" | sed '/^[[:space:]]*```json[[:space:]]*$/d; /^[[:space:]]*```[[:space:]]*$/d')

    if echo "$cleaned" | jq -e '.commands and (.commands | type == "array")' > /dev/null 2>&1; then
        echo "$cleaned"
        return 0
    fi

    extracted=$(printf '%s' "$cleaned" | jq -Rrs 'capture("(?s)\\{.*\\}") | .string' 2>/dev/null)
    if [[ -n "$extracted" ]] && echo "$extracted" | jq -e '.commands and (.commands | type == "array")' > /dev/null 2>&1; then
        echo "$extracted"
        return 0
    fi

    return 1
}

load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        source "$CONFIG_FILE"
    fi
    API_KEY=$(echo "${API_KEY:-}" | tr -d '[:cntrl:]')
    MODEL=$(echo "${MODEL:-$DEFAULT_MODEL}" | tr -d '[:cntrl:]')
    ENDPOINT=$(echo "${ENDPOINT:-$DEFAULT_ENDPOINT}" | tr -d '[:cntrl:]')
}

save_config() {
    mkdir -p "$(dirname "$CONFIG_FILE")"
    API_KEY=$(echo "$API_KEY" | tr -d '[:cntrl:]')
    MODEL=$(echo "$MODEL" | tr -d '[:cntrl:]')
    ENDPOINT=$(echo "$ENDPOINT" | tr -d '[:cntrl:]')
    cat > "$CONFIG_FILE" << EOF
API_KEY="$API_KEY"
MODEL="$MODEL"
ENDPOINT="$ENDPOINT"
EOF
    chmod 600 "$CONFIG_FILE"
    echo "Configuration saved to $CONFIG_FILE"
}

config_interactive() {
    echo "Ask CLI Configuration"
    echo "====================="
    echo ""
    
    read -rp "Enter your OpenRouter API Key: " -s input_key
    echo ""
    if [[ -n "$input_key" ]]; then
        API_KEY=$(echo "$input_key" | tr -d '[:cntrl:]')
    fi
    
    read -rp "Enter model (default: $DEFAULT_MODEL) [$MODEL]: " input_model
    if [[ -n "$input_model" ]]; then
        MODEL="$input_model"
    fi
    
    read -rp "Enter API endpoint (default: $DEFAULT_ENDPOINT) [$ENDPOINT]: " input_endpoint
    if [[ -n "$input_endpoint" ]]; then
        ENDPOINT="$input_endpoint"
    fi
    
    save_config
}

show_help() {
    cat << EOF
Ask CLI - AI-powered command suggestions

Usage:
  ask QUESTION        Ask AI for command suggestions
  ask -c, --config    Configure API settings
  ask -h, --history   View command history
  ask -k, --key KEY   Set API key directly
  ask -m, --model MODEL  Set model directly
  ask --help          Show this help

During command selection:
  Enter   Run the selected command
  i       Show explanation for the highlighted command
  q/Esc   Quit without running

Configuration is stored in: ~/.config/ask/config.conf
History is stored in: ~/.config/ask/history.json
EOF
}

init_history() {
    if [[ ! -f "$HISTORY_FILE" ]]; then
        echo "[]" > "$HISTORY_FILE"
    fi
}

add_to_history() {
    local question="$1"
    local command="$2"
    local explanation="$3"
    local timestamp
    timestamp=$(date -Iseconds)
    
    init_history
    
    local entry
    entry=$(jq -n \
        --arg q "$question" \
        --arg c "$command" \
        --arg e "$explanation" \
        --arg t "$timestamp" \
        '{question: $q, command: $c, explanation: $e, timestamp: $t}')
    
    local temp_file
    temp_file=$(mktemp)
    jq ". + [$entry]" "$HISTORY_FILE" > "$temp_file" && mv "$temp_file" "$HISTORY_FILE"
}

show_history() {
    init_history
    
    if [[ ! -s "$HISTORY_FILE" ]] || [[ $(jq 'length' "$HISTORY_FILE") -eq 0 ]]; then
        echo "No history found."
        return
    fi
    
    local temp_file
    temp_file=$(mktemp)
    # Get last 100 entries, reverse order (newest first)
    jq -r 'if length > 100 then .[-100:] else . end | reverse | .[] | "\(.timestamp) | \(.command) | \(.question) | \(.explanation)"' "$HISTORY_FILE" > "$temp_file"
    
    local selection
    selection=$(cat "$temp_file" | \
        fzf \
            --with-nth=2,3 \
            --delimiter='|' \
            --preview='echo "Command: {2}

Question: {3}

Explanation: {4}"' \
            --preview-window=up:5:wrap \
            --header="Select command to run (Enter=run, q/Esc=quit)" \
            --height=80% \
            --layout=reverse)
    
    rm -f "$temp_file"
    
    if [[ -n "$selection" ]]; then
        local cmd
        cmd=$(echo "$selection" | cut -d'|' -f2 | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        echo "Running: $cmd"
        history -s "$cmd"
        eval "$cmd"
    fi
}

call_ai() {
    local question="$1"
    
    if [[ -z "$API_KEY" ]]; then
        echo "Error: API key not configured. Run 'ask -c' to configure." >&2
        return 1
    fi
    
    # Check cache first
    local cached_response
    if cached_response=$(check_cache "$question"); then
        echo "Using cached response" >&2
        echo "$cached_response"
        return 0
    fi
    
    local system_prompt
    system_prompt=$(cat << 'EOF'
Provide shell commands as JSON. Format: {"commands":[{"command":"cmd","explanation":"desc","danger_level":"safe|warning|dangerous"}]}. Provide 3-5 commands. Mark rm -rf, dd as dangerous.
EOF
)
    
    # Create temp file for curl output
    local temp_curl_out
    temp_curl_out=$(mktemp)
    
    # Start curl in background
    (curl -s -w "\n%{http_code}" "$ENDPOINT" \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer $API_KEY" \
        -H "HTTP-Referer: https://github.com/dalekirkwood/MrAsk" \
        -H "X-Title: MrAsk" \
        --connect-timeout 10 \
        --max-time 60 \
        -d "$(jq -n \
            --arg model "$MODEL" \
            --arg system "$system_prompt" \
            --arg user "$question" \
            '{
                model: $model,
                messages: [
                    {role: "system", content: $system},
                    {role: "user", content: $user}
                ]
            }')" > "$temp_curl_out" 2>/dev/null) &
    
    local curl_pid=$!
    
    # Show spinner while waiting
    spinner $curl_pid
    
    # Wait for curl to finish
    wait $curl_pid
    local curl_exit=$?
    
    local response
    response=$(cat "$temp_curl_out")
    rm -f "$temp_curl_out"
    
    if [[ $curl_exit -ne 0 ]]; then
        echo "Error: API request timed out or failed" >&2
        return 1
    fi
    
    local http_code
    http_code=$(echo "$response" | tail -n1)
    local body
    body=$(echo "$response" | sed '$d' | sed '/^[[:space:]]*$/d')
    
    if [[ "$http_code" != "200" ]]; then
        echo "Error: API request failed (HTTP $http_code)" >&2
        echo "$body" | jq -r '.error.message // .' 2>/dev/null || echo "$body" >&2
        return 1
    fi
    
    # Save to cache
    save_cache "$question" "$body"
    
    echo "$body"
}

select_and_run() {
    local question="$1"
    local ai_response="$2"
    
    local commands_content
    commands_content=$(echo "$ai_response" | jq -r '.choices[0].message.content // ""')

    local commands_json
    commands_json=$(extract_commands_json "$commands_content")

    if [[ -z "$commands_json" ]]; then
        echo "Error: Invalid response from AI" >&2
        echo "$commands_content" >&2
        return 1
    fi
    
    local temp_commands
    temp_commands=$(mktemp)
    echo "$commands_json" > "$temp_commands"
    
    # Create preview script to avoid escaping issues
    local preview_script
    preview_script=$(mktemp)
    cat > "$preview_script" << 'SCRIPT'
#!/bin/bash
line="$1"
file="$2"
cmd=$(echo "$line" | sed 's/^\[[^]]*\] //')
jq -r --arg cmd "$cmd" '.commands[] | select(.command == $cmd) | .explanation' "$file"
SCRIPT
    chmod +x "$preview_script"
    
    # Create info script
    local info_script
    info_script=$(mktemp)
    cat > "$info_script" << 'SCRIPT'
#!/bin/bash
line="$1"
file="$2"
cmd=$(echo "$line" | sed 's/^\[[^]]*\] //')
jq -r --arg cmd "$cmd" '.commands[] | select(.command == $cmd) | "Command: \(.command)\n\nExplanation: \(.explanation)\n\nDanger Level: \(.danger_level)"' "$file" | less -R
SCRIPT
    chmod +x "$info_script"
    
    local selected_line
    selected_line=$(jq -r '.commands[] | "[\(.danger_level)] \(.command)"' "$temp_commands" | \
        fzf \
            --preview="$preview_script {} $temp_commands" \
            --preview-window=right:50%:wrap \
            --bind="i:execute($info_script {} $temp_commands)" \
            --header="Select a command (Enter=run, i=detailed info, q=quit)" \
            --height=80% \
            --layout=reverse)
    
    rm -f "$temp_commands" "$preview_script" "$info_script"
    
    if [[ -n "$selected_line" ]]; then
        local cmd
        cmd=$(echo "$selected_line" | sed 's/^\[[^]]*\] //')
        
        local explanation
        explanation=$(echo "$commands_json" | jq -r --arg cmd "$cmd" '.commands[] | select(.command == $cmd) | .explanation')
        
        add_to_history "$question" "$cmd" "$explanation"
        
        echo "Running: $cmd"
        echo ""
        history -s "$cmd"
        eval "$cmd"
    fi
}

main() {
    load_config
    
    if [[ $# -eq 0 ]]; then
        show_help
        exit 0
    fi
    
    case "$1" in
        -c|--config)
            config_interactive
            exit 0
            ;;
        -h|--history)
            show_history
            exit 0
            ;;
        -k|--key)
            if [[ -z "$2" ]]; then
                echo "Error: API key required" >&2
                exit 1
            fi
            API_KEY=$(echo "$2" | tr -d '[:cntrl:]')
            save_config
            exit 0
            ;;
        -m|--model)
            if [[ -z "$2" ]]; then
                echo "Error: Model name required" >&2
                exit 1
            fi
            MODEL=$(echo "$2" | tr -d '[:cntrl:]')
            save_config
            exit 0
            ;;
        --help|-help)
            show_help
            exit 0
            ;;
        -*)
            echo "Unknown option: $1" >&2
            show_help
            exit 1
            ;;
        *)
            local question="$*"
            
            if ! command -v jq &> /dev/null; then
                echo "Error: jq is required. Install with: sudo apt install jq" >&2
                exit 1
            fi
            
            if ! command -v fzf &> /dev/null; then
                echo "Error: fzf is required. Install with: sudo apt install fzf" >&2
                exit 1
            fi
            
            if ! command -v curl &> /dev/null; then
                echo "Error: curl is required. Install with: sudo apt install curl" >&2
                exit 1
            fi
            
            echo "Asking AI: $question"
            echo ""
            
            local ai_response
            ai_response=$(call_ai "$question")
            
            if [[ $? -ne 0 ]]; then
                echo "$ai_response"
                exit 1
            fi
            
            select_and_run "$question" "$ai_response"
            ;;
    esac
}

main "$@"
